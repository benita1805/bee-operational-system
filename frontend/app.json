{
  "expo": {
    "name": "Buzz-Off",
    "slug": "buzzoff",
    "scheme": "buzzoff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.buzzoff.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.buzzoff.app",
      "buildNumber": "1.0.0"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
