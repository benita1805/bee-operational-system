{
    "name": "buzzoff-api",
    "version": "1.0.0",
    "description": "Production-ready agricultural API for Buzz-Off",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "db:init": "node scripts/init-db.js",
        "db:seed": "node scripts/seed-db.js"
    },
    "keywords": [
        "agriculture",
        "beekeeping",
        "offline-sync",
        "rest-api"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "axios": "^1.13.5",
        "buzzoff": "file:../frontend",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.17.2",
        "twilio": "^5.12.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/pg": "^8.16.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
